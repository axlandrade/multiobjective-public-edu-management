    def toggle_mode(self):
        idx = self.tab_widget.currentIndex()
        if idx == 0: # Validação
            self.run_button.show(); self.run_button.setText("Executar Validação")
            self.pop_spinbox.setValue(200); self.ngen_spinbox.setValue(100)
            self.cxpb_slider.setValue(70); self.mutpb_slider.setValue(20)
            self.run_button.setEnabled(True)
        elif idx == 1: # Real
            self.run_button.show(); self.run_button.setText("Executar Análise")
            self.pop_spinbox.setValue(2000); self.ngen_spinbox.setValue(1000)
            self.cxpb_slider.setValue(50); self.mutpb_slider.setValue(50)
            self.run_button.setEnabled(self.real_data_path_processed is not None)
        else: # Visualização
            self.run_button.hide()
            self.update_sol_combo()

    def update_sol_combo(self):
        self.viz_sol_combo.clear()
        if self.current_partitions:
            self.viz_sol_combo.addItems(list(self.current_partitions.keys()))
        else:
            self.viz_sol_combo.addItem("Nenhum resultado disponível")
    
    def update_cluster_combo(self):
        self.viz_cluster_combo.clear()
        sol_id = self.viz_sol_combo.currentText()
        if not sol_id or sol_id == "Nenhum resultado disponível": return
        
        partition = self.current_partitions[sol_id]
        clusters = {}
        for node, cluster_id in partition.items():
            clusters.setdefault(cluster_id, []).append(node)
        
        sorted_clusters = sorted(clusters.items(), key=lambda item: len(item[1]), reverse=True)
        for cid, nodes in sorted_clusters:
            self.viz_cluster_combo.addItem(f"Cluster {cid} ({len(nodes)} nós)", userData=nodes)

    # --- Lógica de Pré-visualização da Rede Bruta ---
    def preview_raw_network(self):
        if not self.real_data_path_processed:
            self.status_label.setText("Erro: Nenhum arquivo processado.")
            return
        limit = self.viz_limit_spin.value()
        self.status_label.setText(f"Gerando pré-visualização (Top {limit} nós)...")
        self.btn_preview_net.setEnabled(False)
        # Inicia o worker com raw_viz=True
        self.viz_worker = VisualizationWorker(self.real_data_path_processed, raw_viz=True, limit_nodes=limit)
        self.viz_worker.finished.connect(self.on_raw_viz_finished)
        self.viz_worker.start()

    def on_raw_viz_finished(self, H, pos):
        self.btn_preview_net.setEnabled(True)
        if H is None: 
            self.status_label.setText(f"Erro na visualização: {pos}")
            return
        
        self.status_label.setText("Pré-visualização gerada.")
        self.results_tabs.setCurrentIndex(1) # Muda para aba de visualização
        self.plot_graph_on_canvas(H, pos, self.viz_canvas, f"Pré-visualização da Rede (Top {len(H.nodes)} Hubs)")

    # --- Lógica de Visualização de Cluster ---
    def visualize_cluster(self):
        nodes = self.viz_cluster_combo.currentData()
        if not nodes: return
        self.viz_button.setEnabled(False); self.viz_button.setText("Gerando...")
        self.status_label.setText(f"Gerando visualização para {len(nodes)} nós...")
        
        data_path = self.current_analysis_file
        self.viz_worker = VisualizationWorker(data_path, nodes)
        self.viz_worker.finished.connect(self.on_cluster_viz_finished)
        self.viz_worker.start()

    def on_cluster_viz_finished(self, H, pos):
        self.viz_button.setEnabled(True); self.viz_button.setText("Visualizar Cluster")
        if H is None: 
            self.status_label.setText(f"Erro: {pos}")
            return
        
        self.status_label.setText("Visualização do cluster gerada.")
        self.results_tabs.setCurrentIndex(1) # Muda para aba de visualização
        
        risks = [d.get('positive_prob', 0) for u, v, d in H.edges(data=True)]
        avg_risk = np.mean(risks) if risks else 0
        self.plot_graph_on_canvas(H, pos, self.viz_canvas, f"Cluster Selecionado ({len(H.nodes)} nós) | Risco Médio: {avg_risk:.2f}")

    # --- Função Única de Plotagem ---
    def plot_graph_on_canvas(self, H, pos, canvas_obj, title):
        canvas_obj.axes.clear()
        
        # Agregação Visual
        G_view = nx.Graph()
        edge_weights = {} 
        edge_risks = {}
        
        for u, v, data in H.edges(data=True):
            key = tuple(sorted((u, v)))
            edge_weights[key] = edge_weights.get(key, 0) + 1
            edge_risks[key] = edge_risks.get(key, 0.0) + data.get('positive_prob', 0.5)
        
        for (u, v), count in edge_weights.items():
            avg_risk = edge_risks[(u, v)] / count
            G_view.add_edge(u, v, weight=count, risk=avg_risk)
        
        G_view.add_nodes_from(H.nodes())

        num_nodes = len(G_view.nodes())
        d = dict(G_view.degree)
        base_size = 3000 / (num_nodes ** 0.6) if num_nodes > 0 else 300
        node_sizes = [v * base_size for v in d.values()] if d else 300
        
        edges = G_view.edges(data=True)
        edge_colors = []
        for u, v, data in edges:
            risk = data['risk']
            if risk < 0.4: color = 'green'
            elif risk < 0.7: color = '#FFC107'
            else: color = 'red'
            edge_colors.append(color)
        
        widths = [1 + np.log(data['weight']) * 2 for u, v, data in edges]

        nx.draw_networkx_nodes(G_view, pos, ax=canvas_obj.axes, node_size=node_sizes, node_color='#3366cc', alpha=0.8)
        nx.draw_networkx_edges(G_view, pos, ax=canvas_obj.axes, edge_color=edge_colors, width=widths, alpha=0.6)
        
        # Labels apenas para os Top 5 nós se o grafo for grande
        if num_nodes < 50:
            nx.draw_networkx_labels(G_view, pos, ax=canvas_obj.axes, font_size=10, font_family='sans-serif', font_weight='bold')
        else:
            top_nodes = sorted(d, key=d.get, reverse=True)[:5]
            labels = {n: n for n in top_nodes}
            nx.draw_networkx_labels(G_view, pos, labels=labels, ax=canvas_obj.axes, font_size=10, font_color='black', font_weight='bold')

        canvas_obj.axes.set_title(title, fontsize=10)
        canvas_obj.axes.axis('off')
        canvas_obj.draw()

    # (Restante das funções: process_real_data, on_data_processed, start_analysis, display_results, etc...)
    def process_real_data(self):
        input_path, _ = QFileDialog.getOpenFileName(self, "Abrir Dados Brutos", "", "CSV (*.csv)")
        if not input_path: return
        self.status_label.setText("Processando..."); self.run_button.setEnabled(False)
        output_path = "data/rede_real_input_ui.csv"
        self.worker_thread = DataProcessingWorker(input_path, output_path)
        self.worker_thread.finished.connect(self.on_data_processed)
        self.worker_thread.start()

    def on_data_processed(self, output_path, message):
        self.status_label.setText(message)
        if output_path:
            self.real_data_path_processed = output_path
            self.file_label.setText(f"Pronto: {os.path.basename(output_path)}")
            self.run_button.setEnabled(True)

    def start_analysis(self):
        self.run_button.setEnabled(False); self.run_button.setText("Executando...")
        self.progress_bar.setValue(0); pop, ngen, cxpb, mutpb = self.pop_spinbox.value(), self.ngen_spinbox.value(), self.cxpb_slider.value()/100.0, self.mutpb_slider.value()/100.0
        
        # Reseta para aba de estatísticas ao iniciar
        self.results_tabs.setCurrentIndex(0)

        if self.tab_widget.currentIndex() == 0: # Validação
            path = self.instance_combo.currentText()
            if not path or "Nenhuma" in path: self.status_label.setText("Erro: Selecione uma instância."); return
            self.current_analysis_file = path
            self.progress_bar.setRange(0, 0)
            self.worker_thread = ValidationWorker(path, pop, ngen, cxpb, mutpb)
            self.worker_thread.status_update.connect(self.update_status)
        else: # Real
            if not self.real_data_path_processed: self.status_label.setText("Erro: Processe os dados primeiro."); return
            self.current_analysis_file = self.real_data_path_processed
            self.worker_thread = RealDataWorker(self.real_data_path_processed, pop, ngen, cxpb, mutpb)
            self.worker_thread.progress.connect(self.update_progress)
        
        self.worker_thread.finished.connect(self.display_results)
        self.worker_thread.start()
    
    def display_results(self, results):
        self.run_button.setEnabled(True); self.progress_bar.setRange(0, 100); self.progress_bar.setValue(100)
        if 'error' in results: self.status_label.setText(f"Erro: {results['error']}"); return
        
        self.canvas.axes.clear()
        
        if self.tab_widget.currentIndex() == 0:
            self.run_button.setText("Executar Validação"); self.status_label.setText("Validação Concluída!")
            self.time_label_1.setText(f"Tempo Exato: {results['time_exact']:.2f} s"); self.time_label_1.show()
            self.time_label_2.setText(f"Tempo Heurística: {results['time_heuristic']:.2f} s")
            df_e=pd.DataFrame(results['df_exact']); self._populate_table(self.table1,df_e,"Ótima (Exato)")
            df_h=pd.DataFrame(results['df_heuristic']); self._populate_table(self.table2,df_h,"Aproximada (AG)")
            self.current_pareto_df=pd.concat([df_e,df_h]); 
            self.current_partitions=results.get('partitions', None)
            
            if not df_e.empty: self.canvas.axes.plot(df_e['num_clusters_f2'],df_e['disagreement_f1'],marker='*',ls='--',label='Ótima (Exato)',color='blue')
            if not df_h.empty: self.canvas.axes.scatter(df_h['num_clusters_f2'],df_h['disagreement_f1'],marker='o',label='Aproximada (AG)',s=100,color='orange')
            self.canvas.axes.set_title("Comparativo de Fronteiras de Pareto"); self.download_button_json.hide()
        else:
            self.run_button.setText("Executar Análise"); self.status_label.setText("Análise Concluída!")
            stats=results['stats']; self.time_label_1.hide(); self.time_label_2.setText(f"Tempo Total: {stats['total_time_minutes']:.2f} min | Soluções: {stats['num_pareto_solutions']}")
            df_p=pd.DataFrame(results['pareto_df']); self._populate_table(self.table1,df_p,"Fronteira de Pareto"); self.table2.hide()
            self.current_pareto_df=df_p; self.current_partitions=results['partitions']
            if not df_p.empty: self.canvas.axes.scatter(df_p['num_clusters_f2'],df_p['disagreement_f1'],marker='o',label='Fronteira (AG)',color='green')
            self.canvas.axes.set_title("Fronteira de Pareto (Dados Reais)"); self.download_button_json.show()
        
        self.canvas.axes.set_xlabel("Nº Clusters (f2)"); self.canvas.axes.set_ylabel("Desequilíbrio (f1)")
        self.canvas.axes.grid(True); self.canvas.axes.legend(); self.canvas.draw()
        self.download_button_csv.setEnabled(True); 
        if self.current_partitions: self.download_button_json.setEnabled(True)
        self.update_sol_combo()

    def save_csv(self):
        if self.current_pareto_df is not None:
            path, _ = QFileDialog.getSaveFileName(self, "Salvar CSV", "results.csv", "CSV Files (*.csv)")
            if path: self.current_pareto_df.to_csv(path, index=False)
    def save_json(self):
        if self.current_partitions is not None:
            path, _ = QFileDialog.getSaveFileName(self, "Salvar JSON", "partitions.json", "JSON Files (*.json)")
            if path:
                with open(path, 'w') as f: json.dump(self.current_partitions, f, indent=4)
    def populate_instances(self):
        self.instance_combo.clear(); files=sorted(glob.glob("data/run1_*.csv"))
        if files: self.instance_combo.addItems(files)
        else: self.instance_combo.addItem("Nenhuma instância encontrada")
    def generate_instances(self):
        self.status_label.setText("Gerando..."); QApplication.processEvents(); generate_multigraph_instances()
        self.status_label.setText("Instâncias geradas."); self.populate_instances()
    def update_progress(self, v, t): self.progress_bar.setValue(v); self.status_label.setText(t)
    def update_status(self, t): self.status_label.setText(t)
    def _populate_table(self, table, df, title):
        table.clear(); table.show(); table.setRowCount(0); table.setColumnCount(0)
        if df.empty: return
        table.setRowCount(len(df)+1); table.setColumnCount(len(df.columns))
        t_item=QTableWidgetItem(title); font=QFont(); font.setBold(True); t_item.setFont(font); table.setItem(0,0,t_item); table.setSpan(0,0,1,len(df.columns))
        table.setHorizontalHeaderLabels(df.columns)
        for i, row in df.iterrows():
            for j, val in enumerate(row): table.setItem(i+1, j, QTableWidgetItem(f"{val:.4f}" if isinstance(val, float) else str(val)))
        table.horizontalHeader().setSectionResizeMode(QHeaderView.Stretch)

if __name__ == "__main__":
    app = QApplication(sys.argv)
    window = MainWindow()
    window.show()
    sys.exit(app.exec())
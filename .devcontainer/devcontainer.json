{
    "name": "Dissertacao Axl (CLI)",
    "build": {
        "dockerfile": "../Dockerfile",
        "context": ".."
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python"
            ]
        }
    },
    "forwardPorts": [
        8501
    ],
    "portsAttributes": {
        "8501": {
            "label": "Streamlit dashboard",
            "onAutoForward": "notify"
        }
    },
    "postCreateCommand": "pip install -e .",
    "remoteUser": "root"
}
